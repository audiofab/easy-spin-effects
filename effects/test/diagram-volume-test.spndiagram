{
  "version": "1.0",
  "metadata": {
    "name": "Diagram Volume Test",
    "description": "Simple block-diagram test: POT0 controls a volume block applied to both channels. Used to verify the .spndiagram format compiles and runs end-to-end."
  },
  "blocks": [
    {
      "id": "pot0",
      "type": "input.pot",
      "parameters": { "potNumber": 0 },
      "position": { "x": 0, "y": 0 }
    },
    {
      "id": "adc_l",
      "type": "input.adc",
      "parameters": { "adcNumber": 0 },
      "position": { "x": 0, "y": 150 }
    },
    {
      "id": "adc_r",
      "type": "input.adc",
      "parameters": { "adcNumber": 1 },
      "position": { "x": 0, "y": 300 }
    },
    {
      "id": "vol_l",
      "type": "math.volume",
      "parameters": { "gain": 0 },
      "position": { "x": 250, "y": 150 }
    },
    {
      "id": "vol_r",
      "type": "math.volume",
      "parameters": { "gain": 0 },
      "position": { "x": 250, "y": 300 }
    },
    {
      "id": "dac_l",
      "type": "output.dac",
      "parameters": { "dacNumber": 0 },
      "position": { "x": 500, "y": 150 }
    },
    {
      "id": "dac_r",
      "type": "output.dac",
      "parameters": { "dacNumber": 1 },
      "position": { "x": 500, "y": 300 }
    }
  ],
  "connections": [
    {
      "id": "c_adc_l_to_vol_l",
      "from": { "blockId": "adc_l", "portId": "out" },
      "to":   { "blockId": "vol_l", "portId": "input" }
    },
    {
      "id": "c_adc_r_to_vol_r",
      "from": { "blockId": "adc_r", "portId": "out" },
      "to":   { "blockId": "vol_r", "portId": "input" }
    },
    {
      "id": "c_pot_to_vol_l",
      "from": { "blockId": "pot0", "portId": "out" },
      "to":   { "blockId": "vol_l", "portId": "volume" }
    },
    {
      "id": "c_pot_to_vol_r",
      "from": { "blockId": "pot0", "portId": "out" },
      "to":   { "blockId": "vol_r", "portId": "volume" }
    },
    {
      "id": "c_vol_l_to_dac_l",
      "from": { "blockId": "vol_l", "portId": "output" },
      "to":   { "blockId": "dac_l", "portId": "in" }
    },
    {
      "id": "c_vol_r_to_dac_r",
      "from": { "blockId": "vol_r", "portId": "output" },
      "to":   { "blockId": "dac_r", "portId": "in" }
    }
  ]
}
